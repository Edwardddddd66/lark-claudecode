# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书域名：国内版用 https://open.feishu.cn，国际版(Lark)用 https://open.larksuite.com
# FEISHU_DOMAIN=https://open.larksuite.com

# Claude 默认配置
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_CWD=~

# 工具权限模式：bypassPermissions（跳过所有确认，推荐个人使用）
#              default（需要确认敏感操作）
PERMISSION_MODE=bypassPermissions

# （可选）Claude CLI 路径，留空则自动从 PATH 查找
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# 后端 provider：anthropic = Claude Max/Pro 订阅（默认），mimo = 小米 MiMo API
# 在 Lark 里用 /provider 随时切换；切到 mimo 需配置下方 MIMO_API_KEY
DEFAULT_PROVIDER=anthropic
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# MIMO_API_KEY=tp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MIMO_MODEL=mimo-v2.5-pro
